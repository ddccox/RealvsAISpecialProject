<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Deepfake vs. Real: AI Literacy Training</title>
    <!-- FontAwesome Icons for UI styling -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --bg-dark: #0a0f1d;
            --bg-card: #131c33;
            --primary: #00f0ff;
            --primary-glow: rgba(0, 240, 255, 0.3);
            --secondary: #bd00ff;
            --success: #00ff66;
            --error: #ff0055;
            --text-main: #f0f4f8;
            --text-muted: #8a99ad;
            --border: #223154;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            user-select: none;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            overflow-x: hidden;
            height: 100vh;
        }

        /* App Layout Container */
        #app-container {
            width: 100%;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        /* Tech Grid Background */
        .grid-bg {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background-image: linear-gradient(var(--border) 1px, transparent 1px), linear-gradient(90deg, var(--border) 1px, transparent 1px);
            background-size: 40px 40px;
            opacity: 0.15;
            z-index: 0;
            pointer-events: none;
        }

        /* Screen Base Configuration */
        .screen {
            position: absolute;
            top: 0; left: 0; width: 100%; min-height: 100vh;
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            z-index: 10;
            box-sizing: border-box;
            opacity: 0;
            transition: opacity 0.4s ease-in-out;
        }

        .screen.active {
            display: flex;
            opacity: 1;
            position: relative;
        }

        /* Typography & Cyber UI elements */
        h1, h2, h3 {
            text-transform: uppercase;
            letter-spacing: 2px;
            text-shadow: 0 0 10px var(--primary-glow);
            text-align: center;
        }

        .cyber-title {
            font-size: 3.5rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 0.5rem;
        }

        .cyber-subtitle {
            font-size: 1.5rem;
            color: var(--text-muted);
            margin-bottom: 2rem;
        }

        .card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 2rem;
            width: 100%;
            max-width: 800px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            margin-bottom: 1.5rem;
            position: relative;
            overflow: hidden;
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 4px; height: 100%;
            background: var(--primary);
        }

        /* Interactive UI Controls */
        .btn-group {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
            margin-top: 1.5rem;
            width: 100%;
            max-width: 800px;
        }

        button {
            background: transparent;
            border: 2px solid var(--primary);
            color: var(--primary);
            padding: 0.8rem 2rem;
            font-size: 1rem;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-radius: 4px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            box-shadow: 0 0 10px rgba(0, 240, 255, 0.1);
        }

        button:hover:not(:disabled) {
            background: var(--primary);
            color: var(--bg-dark);
            box-shadow: 0 0 20px var(--primary-glow);
            transform: translateY(-2px);
        }

        button.secondary {
            border-color: var(--secondary);
            color: var(--secondary);
        }

        button.secondary:hover {
            background: var(--secondary);
            color: var(--text-main);
            box-shadow: 0 0 20px rgba(189, 0, 255, 0.4);
        }

        button:disabled {
            border-color: var(--border);
            color: var(--text-muted);
            cursor: not-allowed;
            opacity: 0.5;
        }

        /* Header Navigation for Dashboards */
        .app-header {
            width: 100%;
            background: rgba(19, 28, 51, 0.85);
            border-bottom: 1px solid var(--border);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
            backdrop-filter: blur(10px);
        }

        .hud-stats {
            display: flex;
            gap: 2rem;
        }

        .hud-stat {
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        .hud-stat span {
            color: var(--primary);
            font-weight: bold;
        }

        /* Component-Specific System Mockups */
        .video-canvas-container {
            position: relative;
            width: 100%;
            max-width: 640px;
            aspect-ratio: 16/9;
            background: #000;
            border: 2px solid var(--border);
            border-radius: 6px;
            overflow: hidden;
            margin: 0 auto 1.5rem auto;
        }

        canvas {
            width: 100%;
            height: 100%;
            display: block;
        }

        .video-overlay-ui {
            position: absolute;
            top: 10px; right: 10px;
            background: rgba(0,0,0,0.7);
            padding: 4px 10px;
            border-radius: 4px;
            font-family: monospace;
            color: var(--error);
            border: 1px solid var(--error);
            font-size: 0.8rem;
            animation: blink 1s infinite alternate;
        }

        @keyframes blink { 0% { opacity: 0.4; } 100% { opacity: 1; } }

        .zoom-lens {
            position: absolute;
            border: 2px dashed var(--primary);
            width: 80px; height: 80px;
            border-radius: 50%;
            pointer-events: none;
            display: none;
            box-shadow: 0 0 10px var(--primary-glow);
        }

        /* Checkbox lists for detection verification */
        .checklist-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.8rem;
            margin: 1.5rem 0;
        }

        .check-item {
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
            padding: 0.8rem;
            border-radius: 4px;
            display: flex;
            align-items: center;
            gap: 0.8rem;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .check-item:hover {
            border-color: var(--primary);
            background: rgba(0, 240, 255, 0.02);
        }

        .check-item input[type="checkbox"] {
            accent-color: var(--primary);
            width: 18px; height: 18px;
        }

        /* Dynamic Options Grid */
        .options-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
            margin-top: 1rem;
        }

        .option-card {
            background: rgba(255,255,255,0.03);
            border: 2px solid var(--border);
            border-radius: 6px;
            padding: 1.5rem 1rem;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s ease;
            font-weight: bold;
        }

        .option-card:hover {
            border-color: var(--primary);
            background: rgba(0,240,255,0.05);
        }

        .option-card.selected {
            border-color: var(--primary);
            background: rgba(0, 240, 255, 0.15);
            box-shadow: 0 0 15px var(--primary-glow);
        }

        /* Progress Bar Graphics */
        .xp-bar-container {
            width: 100%;
            background: var(--border);
            height: 12px;
            border-radius: 6px;
            overflow: hidden;
            margin: 0.5rem 0 1.5rem 0;
        }

        .xp-bar-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
            width: 40%;
            transition: width 0.5s ease-out;
        }

        /* Feed Assessment Stream View */
        .social-feed {
            width: 100%;
            max-width: 550px;
            max-height: 480px;
            overflow-y: auto;
            border: 1px solid var(--border);
            background: #070b14;
            padding: 1rem;
            border-radius: 8px;
        }

        .feed-post {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 1rem;
            margin-bottom: 1.5rem;
        }

        .post-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 0.75rem;
        }

        .post-avatar {
            width: 36px; height: 36px;
            background: var(--border);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
        }

        .post-author { font-weight: bold; font-size: 0.95rem; }

        .feed-media-mock {
            width: 100%;
            aspect-ratio: 4/3;
            background: #02060e;
            border-radius: 6px;
            margin: 0.5rem 0;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px dashed var(--border);
            overflow: hidden;
        }

        /* Modal Substructures */
        .modal-mask {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(5, 8, 16, 0.85);
            backdrop-filter: blur(6px);
            z-index: 200;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        /* Leaders & Badges lists */
        .data-list-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.8rem 1rem;
            border-bottom: 1px solid var(--border);
        }
        .data-list-item:last-child { border: none; }

        .badge-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
            text-align: center;
        }

        .badge-icon-box {
            font-size: 2.5rem;
            margin-bottom: 0.5rem;
            color: var(--text-muted);
        }
        .badge-icon-box.unlocked {
            color: var(--primary);
            text-shadow: 0 0 15px var(--primary-glow);
        }

        /* Live Canvas Certificate System */
        #cert-canvas {
            background: #fff;
            max-width: 100%;
            height: auto;
            border: 4px solid var(--border);
            border-radius: 4px;
        }
    </style>
</head>
<body>

    <div class="grid-bg"></div>

    <div id="app-container">

        <!-- CORE HUD HEADER (Visible on dashboard, game screens) -->
        <header class="app-header" id="global-hud" style="display: none;">
            <div style="font-weight: bold; letter-spacing: 1px; color: var(--primary);">
                <i class="fa-solid fa-user-shield"></i> DEEPFAKE DETECTOR HUD
            </div>
            <div class="hud-stats">
                <div class="hud-stat">RANK: <span id="hud-rank">Truth Seeker</span></div>
                <div class="hud-stat">XP: <span id="hud-xp">120</span></div>
                <div class="hud-stat">ACCURACY: <span id="hud-acc">74%</span></div>
            </div>
        </header>

        <!-- SCREEN 1: LANDING PAGE -->
        <section id="scr-landing" class="screen active">
            <div style="text-align: center; max-width: 700px;">
                <div style="font-size: 4rem; color: var(--primary); margin-bottom: 1rem;"><i class="fa-solid fa-eye-slash"></i></div>
                <h1 class="cyber-title">Deepfake vs. Real</h1>
                <h2 class="cyber-subtitle">Can you still trust what you see?</h2>
                <p style="color: var(--text-muted); margin-bottom: 2.5rem; line-height: 1.6;">
                    A gamified multimedia experience that trains Open and Distance e-Learning students to scan anomalies, counter synthetic misinformation, and detect AI-generated media content.
                </p>
                <div class="btn-group">
                    <button onclick="router('scr-dashboard')"><i class="fa-solid fa-terminal"></i> Start Investigation</button>
                    <button class="secondary" onclick="openAboutModal()"><i class="fa-solid fa-circle-info"></i> About Project</button>
                    <button class="secondary" onclick="router('scr-tutorial')"><i class="fa-solid fa-graduation-cap"></i> How To Play</button>
                </div>
            </div>
        </section>

        <!-- SCREEN 3: HOW TO PLAY / TUTORIAL PAGE -->
        <section id="scr-tutorial" class="screen">
            <div class="card">
                <h2>How to Detect a Deepfake</h2>
                <p style="color: var(--text-muted); margin-bottom: 1.5rem; text-align: center;">Analyze video frames methodically using your technical assessment matrix.</p>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; align-items: center;">
                    <div class="video-canvas-container" style="margin:0;">
                        <canvas id="tutorial-canvas"></canvas>
                        <div class="video-overlay-ui"><i class="fa-solid fa-circle"></i> LIVE ANALYSIS</div>
                    </div>
                    <div>
                        <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.8rem;">
                            <li><i class="fa-solid fa-square-check" style="color: var(--primary);"></i> <strong>Look for unnatural blinking:</strong> AI often skips micro-movements.</li>
                            <li><i class="fa-solid fa-square-check" style="color: var(--primary);"></i> <strong>Check lip-sync consistency:</strong> Listen for subtle delays or shifting structures.</li>
                            <li><i class="fa-solid fa-square-check" style="color: var(--primary);"></i> <strong>Observe lighting/shadows:</strong> Watch the nose bridge and dynamic contours.</li>
                            <li><i class="fa-solid fa-square-check" style="color: var(--primary);"></i> <strong>Listen for robotic audio:</strong> Look for flat intonations and synthetic voice stitching.</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="btn-group">
                <button class="secondary" onclick="router('scr-landing')">Back</button>
                <button onclick="router('scr-dashboard')">Skip to Control</button>
                <button onclick="startTrainingFromTutorial()">Start Training Matrix</button>
            </div>
        </section>

        <!-- SCREEN 4: DASHBOARD / MISSION CONTROL -->
        <section id="scr-dashboard" class="screen">
            <div class="card" style="max-width: 850px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                    <h3><i class="fa-solid fa-gauge-high"></i> Welcome, Investigator</h3>
                    <span style="font-family: monospace; color: var(--primary);">SYSTEM: ONLINE</span>
                </div>
                
                <label style="font-size: 0.8rem; color: var(--text-muted); letter-spacing: 1px;">INVESTIGATOR XP PROGRESSION</label>
                <div class="xp-bar-container">
                    <div id="dashboard-xp-bar" class="xp-bar-fill"></div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 250px; gap: 1.5rem;">
                    <div>
                        <h4 style="margin-bottom: 1rem; color: var(--primary); text-transform: uppercase;">Available Assignments</h4>
                        
                        <!-- Level 1 Card Segment -->
                        <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--border); padding: 1rem; border-radius: 6px; margin-bottom: 1rem; display: flex; justify-content: space-between; align-items: center;">
                            <div>
                                <strong style="color: var(--text-main);">LEVEL 1: Case File #01</strong>
                                <div style="font-size: 0.8rem; color: var(--text-muted);">Media Content: Viral Politician Interview</div>
                            </div>
                            <button onclick="loadLevelIntro(1)">Start Case</button>
                        </div>

                        <!-- Level 2 Card Segment -->
                        <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--border); padding: 1rem; border-radius: 6px; margin-bottom: 1rem; display: flex; justify-content: space-between; align-items: center;">
                            <div>
                                <strong style="color: var(--text-main);">LEVEL 2: Case File #02</strong>
                                <div style="font-size: 0.8rem; color: var(--text-muted);">Media Content: Financial App Scam Clip</div>
                            </div>
                            <button id="btn-lvl-2" onclick="loadLevelIntro(2)">Start Case</button>
                        </div>

                        <!-- Level 3 Card Segment -->
                        <div style="background: rgba(255,255,255,0.01); border: 1px solid rgba(34,49,84,0.4); padding: 1rem; border-radius: 6px; display: flex; justify-content: space-between; align-items: center; opacity: 0.6;">
                            <div>
                                <strong style="color: var(--text-muted);"><i class="fa-solid fa-lock"></i> LEVEL 3: Case File #03</strong>
                                <div style="font-size: 0.8rem; color: var(--text-muted);">Media Content: Synthesis Breaking News Event</div>
                            </div>
                            <button disabled>Locked</button>
                        </div>
                    </div>

                    <!-- Sidebar Hub Actions -->
                    <div style="display: flex; flex-direction: column; gap: 0.75rem; border-left: 1px solid var(--border); padding-left: 1.5rem;">
                        <h4 style="color: var(--text-main); font-size: 0.9rem; margin-bottom: 0.5rem;">HUB SYSTEMS</h4>
                        <button class="secondary" style="padding: 0.5rem;" onclick="openBadgesModal()"><i class="fa-solid fa-award"></i> Badges</button>
                        <button class="secondary" style="padding: 0.5rem;" onclick="openLeaderboardModal()"><i class="fa-solid fa-trophy"></i> Leaderboard</button>
                        <button class="secondary" style="padding: 0.5rem;" onclick="openProfileModal()"><i class="fa-solid fa-id-card"></i> Operator Profile</button>
                        <button style="margin-top: auto; border-color: var(--success); color: var(--success);" onclick="router('scr-assessment')"><i class="fa-solid fa-shield-halved"></i> Final Audit</button>
                    </div>
                </div>
            </div>
            <div class="btn-group">
                <button class="secondary" onclick="router('scr-landing')">Disconnect System</button>
            </div>
        </section>

        <!-- SCREEN 5: LEVEL INTRO SCREEN -->
        <section id="scr-level-intro" class="screen">
            <div class="card" style="text-align: center; max-width: 600px;">
                <div style="font-size: 2.5rem; color: var(--secondary); margin-bottom: 1rem;"><i class="fa-solid fa-folder-open"></i></div>
                <h2 id="intro-case-title">CASE FILE #01</h2>
                <hr style="border: none; border-top: 1px solid var(--border); margin: 1.5rem 0;">
                <p id="intro-case-desc" style="font-size: 1.2rem; line-height: 1.6; color: var(--text-main); margin-bottom: 2rem;">
                    A viral interview clip is spreading online. Can you determine whether the video is authentic or AI-generated?
                </p>
                <div style="background: rgba(189,0,255,0.05); border: 1px dashed var(--secondary); padding: 1rem; border-radius: 4px; font-size: 0.9rem; color: var(--text-muted);">
                    <i class="fa-solid fa-circle-exclamation"></i> Warning: Scan metrics require careful evaluation before choosing your submission profile.
                </div>
            </div>
            <div class="btn-group">
                <button class="secondary" onclick="router('scr-dashboard')">Return to Dashboard</button>
                <button onclick="launchGameplayCore()"><i class="fa-solid fa-bolt"></i> Begin Analysis</button>
            </div>
        </section>

        <!-- SCREEN 6: GAMEPLAY / VIDEO ANALYSIS SCREEN -->
        <section id="scr-gameplay" class="screen">
            <div class="card" style="max-width: 950px; padding: 1.5rem;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem;">
                    <h3 id="gameplay-case-id" style="font-size: 1.1rem; color: var(--primary);">CASE #01</h3>
                    <div style="font-family: monospace; font-weight: bold; color: var(--error); font-size: 1.1rem;">
                        <i class="fa-solid fa-clock"></i> TIME REMAINING: <span id="gameplay-timer">00:45</span>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1.3fr 1fr; gap: 1.5rem;">
                    <!-- Video Area Component -->
                    <div>
                        <div class="video-canvas-container">
                            <canvas id="gameplay-canvas"></canvas>
                            <div class="video-overlay-ui" id="media-watermark"><i class="fa-solid fa-microchip"></i> UNVERIFIED FEED</div>
                            <div id="lens-element" class="zoom-lens"></div>
                        </div>
                        <!-- Video Controls -->
                        <div style="display: flex; gap: 0.5rem; justify-content: center; background: rgba(0,0,0,0.3); padding: 0.5rem; border-radius: 4px;">
                            <button style="padding: 0.4rem 1rem; font-size: 0.8rem;" onclick="togglePlayState()"><i id="play-icon" class="fa-solid fa-pause"></i> Pause/Play</button>
                            <button style="padding: 0.4rem 1rem; font-size: 0.8rem;" onclick="restartVideoSim()"><i class="fa-solid fa-arrow-rotate-left"></i> Replay</button>
                            <button class="secondary" style="padding: 0.4rem 1rem; font-size: 0.8rem;" onclick="activateZoomTool()"><i class="fa-solid fa-magnifying-glass-plus"></i> Zoom Grid</button>
                        </div>
                    </div>

                    <!-- Detection Checklist & Classification Option Cards -->
                    <div style="display: flex; flex-direction: column; justify-content: space-between;">
                        <div>
                            <span style="font-size: 0.8rem; font-weight: bold; color: var(--text-muted); letter-spacing: 1px;">DETECTION CHECKLIST</span>
                            <div class="checklist-container">
                                <label class="check-item"><input type="checkbox" id="chk-lip"> Lip-sync mismatch</label>
                                <label class="check-item"><input type="checkbox" id="chk-eye"> Eye distortion</label>
                                <label class="check-item"><input type="checkbox" id="chk-aud"> Audio glitching</label>
                                <label class="check-item"><input type="checkbox" id="chk-warp"> Facial warping</label>
                            </div>

                            <span style="font-size: 0.8rem; font-weight: bold; color: var(--text-muted); letter-spacing: 1px;">DECISION CLASSIFICATION</span>
                            <div class="options-grid">
                                <div class="option-card" onclick="selectDecisionOption(this, 'REAL')">REAL</div>
                                <div class="option-card" onclick="selectDecisionOption(this, 'DEEPFAKE')">DEEPFAKE</div>
                                <div class="option-card" onclick="selectDecisionOption(this, 'AI')">SYNTHETIC</div>
                            </div>
                        </div>

                        <div style="margin-top: 1rem; display: flex; gap: 0.5rem;">
                            <button class="secondary" style="flex: 1; padding: 0.6rem;" onclick="useHintSystem()"><i class="fa-solid fa-lightbulb"></i> Use Hint</button>
                            <button id="btn-submit-gameplay" style="flex: 2; padding: 0.6rem; border-color: var(--success); color: var(--success);" onclick="submitGameplaySelection()" disabled><i class="fa-solid fa-circle-check"></i> Submit Analysis</button>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- SCREEN 7: FEEDBACK SCREEN -->
        <section id="scr-feedback" class="screen">
            <div class="card" style="text-align: center; max-width: 650px;">
                <h2 id="feedback-title" style="margin-bottom: 1rem;">ANALYSIS COMPLETE</h2>
                <div id="feedback-status-banner" style="padding: 0.75rem; border-radius: 4px; font-weight: bold; margin-bottom: 1.5rem;">
                    <!-- Filled dynamically -->
                </div>
                <p id="feedback-explanation" style="line-height: 1.6; margin-bottom: 2rem; color: var(--text-main);">
                    Explanation text...
                </p>
                
