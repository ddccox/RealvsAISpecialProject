    <!-- CORE APPLICATION LOGIC ENGINES (JAVASCRIPT STATE MACHINE) -->
    <script>
        // Application State State-Tree Object
        const state = {
            userXP: 120,
            userAccuracy: 74,
            userRank: "Truth Seeker",
            currentLevel: 1,
            selectedOption: null,
            timerValue: 45,
            timerInterval: null,
            isPlaying: true,
            zoomActive: false,
            // Simulated Level Data Configuration Objects Matrix
            levels: {
                1: {
                    id: "CASE #01",
                    title: "CASE FILE #01",
                    description: "A viral interview clip is spreading online. Can you determine whether the video is authentic or AI-generated?",
                    hint: "Observe the mouth lines. Inconsistent shadow configurations reveal structural rendering mismatches.",
                    correctOption: "DEEPFAKE",
                    explanation: "The video showed unnatural mouth movement and inconsistent eye reflections, indicating AI manipulation.",
                    xpReward: 150
                },
                2: {
                    id: "CASE #02",
                    title: "CASE FILE #02",
                    description: "An emergency asset-loss announcement video is offering dynamic high-speed market returns. Scan carefully.",
                    hint: "The background lighting doesn't sync when the subject turns. Watch facial border contours.",
                    correctOption: "AI",
                    explanation: "Correct! The footage displays complete structural synthetic blending, generating matching human features natively.",
                    xpReward: 250
                }
            },
            // Assessment Sub-system State tracker arrays
            assessmentFeed: [
                { id: 0, type: 'FAKE', verified: false },
                { id: 1, type: 'REAL', verified: false }
            ],
            selectedAssessmentIndex: null,
            completedAssessmentCount: 0
        };

        // Canvas Rendering Frame Animation State Variables
        let gameplayCanvas, gameplayCtx;
        let tutorialCanvas, tutorialCtx;
        let animationFrameId = null;
        let pulseFrame = 0;

        window.onload = function() {
            initCanvases();
            updateHUDDisplay();
            // Start silent looping drawing systems on default backgrounds
            animateTutorialCanvas();
        };

        // Routing engine navigation structure
        function router(screenId) {
            // Stop active rendering loops if jumping screens
            if (animationFrameId) cancelAnimationFrame(animationFrameId);
            clearInterval(state.timerInterval);

            // Hide all views globally
            document.querySelectorAll('.screen').forEach(scr => scr.classList.remove('active'));
            
            // Unveil designated layout
            const targetScreen = document.getElementById(screenId);
            if (targetScreen) targetScreen.classList.add('active');

            // Conditional HUD Visibility evaluation rules
            const hud = document.getElementById('global-hud');
            if (screenId === '留下landing' || screenId === 'scr-landing' || screenId === 'scr-certificate') {
                hud.style.display = 'none';
            } else {
                hud.style.display = 'flex';
            }

            // Screen activation callbacks
            if (screenId === 'scr-tutorial') {
                animateTutorialCanvas();
            } else if (screenId === 'scr-gameplay') {
                runGameplayCanvasLoop();
                startGameplayTimer();
            } else if (screenId === 'scr-certificate') {
                renderLiveCertificate();
            }
        }

        // HUD Synchronizer system
        function updateHUDDisplay() {
            // Re-evaluate rank thresholds dynamically
            if(state.userXP >= 500) state.userRank = "Truth Guardian";
            else if(state.userXP >= 250) state.userRank = "Lead Analyst";

            document.getElementById('hud-rank').innerText = state.userRank;
            document.getElementById('hud-xp').innerText = state.userXP;
            document.getElementById('hud-acc').innerText = state.userAccuracy + "%";

            // Dashboard items update
            document.getElementById('dashboard-xp-bar').style.width = Math.min((state.userXP / 600) * 100, 100) + "%";
            document.getElementById('leaderboard-user-xp').innerText = state.userXP + " XP";
            
            // Profile components syncing values
            document.getElementById('prof-rank').innerText = state.userRank;
            document.getElementById('prof-xp').innerText = state.userXP;
            document.getElementById('prof-acc').innerText = state.userAccuracy + "%";
        }

        // Modal Management functions
        function openAboutModal() { document.getElementById('mdl-about').style.display = 'flex'; }
        function openBadgesModal() { 
            if(state.userAccuracy >= 80) document.getElementById('badge-truth-seeker').classList.add('unlocked');
            if(state.userXP >= 500) document.getElementById('badge-analyst').classList.add('unlocked');
            document.getElementById('mdl-badges').style.display = 'flex'; 
        }
        function openLeaderboardModal() { document.getElementById('mdl-leaderboard').style.display = 'flex'; }
        function openProfileModal() { document.getElementById('mdl-profile').style.display = 'flex'; }
        function closeAllModals() {
            document.querySelectorAll('.modal-mask').forEach(m => m.style.display = 'none');
        }

        // Tutorial Navigation Bridge handler
        function startTrainingFromTutorial() {
            state.currentLevel = 1;
            loadLevelIntro(1);
        }

        // Level Context dynamic compiler
        function loadLevelIntro(lvlNumber) {
            state.currentLevel = lvlNumber;
            const context = state.levels[lvlNumber];
            
            document.getElementById('intro-case-title').innerText = context.title;
            document.getElementById('intro-case-desc').innerText = context.description;
            
            router('scr-level-intro');
        }

        function launchGameplayCore() {
            const context = state.levels[state.currentLevel];
            document.getElementById('gameplay-case-id').innerText = context.id;
            
            // Clear prior states
            state.selectedOption = null;
            document.querySelectorAll('.option-card').forEach(c => c.classList.remove('selected'));
            document.querySelectorAll('.checklist-container input').forEach(i => i.checked = false);
            document.getElementById('btn-submit-gameplay').disabled = true;
            
            router('scr-gameplay');
        }

        // Interactive Analysis Option Selectors
        function selectDecisionOption(element, value) {
            state.selectedOption = value;
            document.querySelectorAll('.option-card').forEach(c => c.classList.remove('selected'));
            element.classList.add('selected');
            
            // Validation requirement verification rule
            document.getElementById('btn-submit-gameplay').disabled = false;
        }

        // Level Gameplay Submit evaluation
        function submitGameplaySelection() {
            clearInterval(state.timerInterval);
            const context = state.levels[state.currentLevel];
            const feedbackTitle = document.getElementById('feedback-title');
            const feedbackStatus = document.getElementById('feedback-status-banner');
            const feedbackExpl = document.getElementById('feedback-explanation');
            const feedbackReward = document.getElementById('feedback-xp-reward');

            if (state.selectedOption === context.correctOption) {
                feedbackTitle.innerText = "ANALYSIS VALIDATED";
                feedbackStatus.innerText = "✓ CORRECT RECOGNITION DETECTED";
                feedbackStatus.style.background = "rgba(0, 255, 102, 0.2)";
                feedbackStatus.style.color = "var(--success)";
                feedbackExpl.innerText = context.explanation;
                
                state.userXP += context.xpReward;
                // Accumulate calculation accuracy optimization step
                state.userAccuracy = Math.min(state.userAccuracy + 6, 96);
                feedbackReward.innerText = "+" + context.xpReward + " XP";
            } else {
                feedbackTitle.innerText = "DIAGNOSTIC FAULT";
                feedbackStatus.innerText = "✕ MEDIA CLASSIFICATION ERROR";
                feedbackStatus.style.background = "rgba(255, 0, 85, 0.2)";
                feedbackStatus.style.color = "var(--error)";
                feedbackExpl.innerText = "Investigation parameters missed critical signature anomalies. Remember: " + context.hint;
                
                state.userAccuracy = Math.max(state.userAccuracy - 8, 45);
                feedbackReward.innerText = "+0 XP";
            }

            // Route adjustment based on depth configuration settings
            const nextBtn = document.getElementById('btn-feedback-next');
            if (state.currentLevel === 1) {
                nextBtn.innerText = "Proceed to Case #02";
                document.getElementById('btn-lvl-2').disabled = false;
            } else {
                nextBtn.innerText = "Advance to Audit Stream";
            }

            updateHUDDisplay();
            router('scr-feedback');
        }

        function advanceFromFeedback() {
            if(state.currentLevel === 1) {
                loadLevelIntro(2);
            } else {
                setupAssessmentFeed();
                router('scr-assessment');
            }
        }

        function useHintSystem() {
            const context = state.levels[state.currentLevel];
            alert("MATRIX DECODED INPUT: " + context.hint);
        }

        // Gameplay Audio/Video Canvas simulation generators
        function initCanvases() {
            gameplayCanvas = document.getElementById('gameplay-canvas');
            gameplayCtx = gameplayCanvas.getContext('2d');
            tutorialCanvas = document.getElementById('tutorial-canvas');
            tutorialCtx = tutorialCanvas.getContext('2d');
            
            gameplayCanvas.width = 640;
            gameplayCanvas.height = 360;
            tutorialCanvas.width = 640;
            tutorialCanvas.height = 360;

            // Setup Feed Click Handlers
            document.getElementById('post-0').onclick = () => selectAssessmentPost(0);
            document.getElementById('post-1').onclick = () => selectAssessmentPost(1);
        }

        function animateTutorialCanvas() {
            pulseFrame++;
            tutorialCtx.fillStyle = '#060a14';
            tutorialCtx.fillRect(0, 0, 640, 360);
            
            // Draw face structure lines wireframe vector graphic
            tutorialCtx.strokeStyle = '#00f0ff';
            tutorialCtx.lineWidth = 1.5;
            tutorialCtx.beginPath();
            tutorialCtx.arc(320, 160, 80, 0, Math.PI * 2);
            tutorialCtx.stroke();

            // Draw eye tracking target reticles
            tutorialCtx.fillStyle = '#bd00ff';
            tutorialCtx.beginPath();
            tutorialCtx.arc(290, 150, 6, 0, Math.PI * 2);
            tutorialCtx.arc(350, 150, 6, 0, Math.PI * 2);
            tutorialCtx.fill();

            // Overlay artificial target markers
            if(Math.sin(pulseFrame * 0.1) > 0) {
                tutorialCtx.strokeStyle = '#ff0055';
                tutorialCtx.strokeRect(270, 135, 40, 30);
                tutorialCtx.strokeRect(330, 135, 40, 30);
                
                tutorialCtx.fillStyle = '#ff0055';
                tutorialCtx.font = '10px monospace';
                tutorialCtx.fillText("ANOMALY: BLINK FAIL", 250, 120);
            }

            animationFrameId = requestAnimationFrame(animateTutorialCanvas);
        }

        function runGameplayCanvasLoop() {
            pulseFrame++;
            gameplayCtx.fillStyle = '#030710';
            gameplayCtx.fillRect(0, 0, 640, 360);

            if(state.isPlaying) {
                // Render simulated human face subject data
                gameplayCtx.strokeStyle = 'rgba(0, 240, 255, 0.4)';
                gameplayCtx.lineWidth = 1;
                // Oval base mask
                gameplayCtx.beginPath();
                gameplayCtx.ellipse(320, 180, 75, 105, 0, 0, Math.PI * 2);
                gameplayCtx.stroke();

                // Structural noise generation step
                gameplayCtx.fillStyle = 'rgba(255, 255, 255, 0.04)';
                for (let i = 0; i < 15; i++) {
                    gameplayCtx.fillRect(Math.random() * 640, Math.random() * 360, 2, 2);
                }

                // Render shifting mouth metrics if level 1 anomalies occur
                gameplayCtx.strokeStyle = state.currentLevel === 1 ? '#ff0055' : '#00ff66';
                gameplayCtx.beginPath();
                // Simulating wave lip motion matrix
                gameplayCtx.moveTo(290, 230);
                gameplayCtx.bezierCurveTo(305, 220 + Math.sin(pulseFrame*0.2)*8, 335, 220 + Math.sin(pulseFrame*0.2)*8, 350, 230);
                gameplayCtx.stroke();
            }

            // Lens scope view modification tracking layer
            if(state.zoomActive) {
                const lens = document.getElementById('lens-element');
                lens.style.display = "block";
                lens.style.left = "280px";
                lens.style.top = "140px";
            } else {
                document.getElementById('lens-element').style.display = "none";
            }

            animationFrameId = requestAnimationFrame(runGameplayCanvasLoop);
        }

        function togglePlayState() {
            state.isPlaying = !state.isPlaying;
            document.getElementById('play-icon').className = state.isPlaying ? "fa-solid fa-pause" : "fa-solid fa-play";
        }

        function restartVideoSim() {
            state.isPlaying = true;
            pulseFrame = 0;
        }

        function activateZoomTool() {
            state.zoomActive = !state.zoomActive;
        }

        function startGameplayTimer() {
            state.timerValue = 45;
            document.getElementById('gameplay-timer').innerText = "00:45";
            
            state.timerInterval = setInterval(() => {
                state.timerValue--;
                let formatSec = state.timerValue < 10 ? "0" + state.timerValue : state.timerValue;
                document.getElementById('gameplay-timer').innerText = "00:" + formatSec;
                
                if(state.timerValue <= 0) {
                    clearInterval(state.timerInterval);
                    alert("Analysis Timeframe expired! Submitting automated zero score.");
                    submitGameplaySelection();
                }
            }, 1000);
        }

        // SCREEN 10: SOCIAL FEED ASSESSMENT IMPLEMENTATION RENDER ENGINES
        function setupAssessmentFeed() {
            state.selectedAssessmentIndex = null;
            state.completedAssessmentCount = 0;
            state.assessmentFeed.forEach(p => p.verified = false);
            
            document.getElementById('audit-done-count').innerText = "0";
            document.getElementById('btn-submit-assessment').disabled = true;
            document.getElementById('audit-selected-text').innerText = "Click an item inside the feed stream to trigger deep diagnostics.";
            
            document.querySelectorAll('.feed-post').forEach(p => {
                p.style.borderColor = "var(--border)";
                p.style.background = "var(--bg-card)";
            });
        }

        function selectAssessmentPost(index) {
            state.selectedAssessmentIndex = index;
            document.querySelectorAll('.feed-post').forEach(p => p.style.background = "var(--bg-card)");
            document.getElementById('post-' + index).style.background = "rgba(189, 0, 255, 0.08)";
            document.getElementById('audit-selected-text').innerText = "Examining Stream Asset #" + (index + 1) + ". Choose validation payload alignment standard below:";
        }

        function markAssessmentPost(decision) {
            if(state.selectedAssessmentIndex === null) {
                alert("Please select a post inside the scrollable live stream window first.");
                return;
            }
            
            const targetPostData = state.state = state.assessmentFeed[state.selectedAssessmentIndex];
            if(!targetPostData.verified) {
                targetPostData.verified = true;
                targetPostData.userChoice = decision;
                state.completedAssessmentCount++;
                
                const element = document.getElementById('post-' + state.selectedAssessmentIndex);
                element.style.borderColor = "var(--primary)";
                
                document.getElementById('audit-done-count').innerText = state.completedAssessmentCount;
                
                if(state.completedAssessmentCount >= 2) {
                    document.getElementById('btn-submit-assessment').disabled = false;
                }
            }
        }

        function processAssessmentResults() {
            // Process dynamic tally score calculations
            let correctlyIdentified = 0;
            state.assessmentFeed.forEach(p => {
                if(p.type === p.userChoice) correctlyIdentified++;
            });

            // Adjust score fields metrics profiles explicitly
            state.userXP += 300; 
            state.userAccuracy = Math.round((state.userAccuracy + 88) / 2);
            
            document.getElementById('results-rank-title').innerText = "RANK: " + state.userRank.toUpperCase();
            document.getElementById('results-acc').innerText = state.userAccuracy + "%";
            document.getElementById('results-solved').innerText = "12";
            document.getElementById('results-xp').innerText = state.userXP;

            router('scr-results');
        }

        function resetAppProgress() {
            state.userXP = 120;
            state.userAccuracy = 74;
            state.userRank = "Truth Seeker";
            document.getElementById('btn-lvl-2').disabled = true;
            updateHUDDisplay();
            router('scr-landing');
        }

